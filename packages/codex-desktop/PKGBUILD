# Maintainer: JuckZ <juckz@foxmail.com>

pkgname=codex-desktop
pkgver=26.707.71524.d361b8a54.gbb6791d5
pkgrel=1
pkgdesc="Unofficial Codex Desktop for Linux, built from the official macOS DMG"
arch=('x86_64')
url="https://github.com/JuckZ/arch-repo"
license=('MIT' 'custom')
install="${pkgname}.install"
depends=(
  'python'
  'p7zip'
  'polkit'
  'curl'
  'unzip'
  'alsa-lib'
  'at-spi2-core'
  'atk'
  'cairo'
  'dbus'
  'glib2'
  'gtk3'
  'libcups'
  'libdrm'
  'libx11'
  'libxcb'
  'libxcomposite'
  'libxdamage'
  'libxext'
  'libxfixes'
  'libxkbcommon'
  'libxrandr'
  'mesa'
  'nspr'
  'nss'
  'pango'
)
makedepends=(
  '7zip'
  'git'
  'nodejs'
  'npm'
  'rust'
  'zstd'
)
optdepends=(
  'nodejs: optional override for the bundled managed Node.js runtime'
  'npm: optional override for Codex CLI install/update flows'
  'zenity: GTK dialog fallback when the Codex CLI is missing'
  'kdialog: KDE dialog fallback when the Codex CLI is missing'
)
conflicts=('codex-desktop-bin' 'openai-codex-desktop')
options=(!debug !strip)

_wrapper_commit='bb6791d59f136dd382a8f1f031f8e225b58991e0'
_dmg_sha256='361b8a54aa4dcbd9aaa9697784526b838569a811d789ea437e925f9855e05fb8'

if [[ "${CODEX_DMG_LOCAL:-0}" == '1' ]]; then
  source=(
    "codex-desktop-linux::git+https://github.com/ilysenko/codex-desktop-linux.git#commit=${_wrapper_commit}"
    'Codex.dmg'
  )
else
  source=(
    "codex-desktop-linux::git+https://github.com/ilysenko/codex-desktop-linux.git#commit=${_wrapper_commit}"
    'Codex.dmg::https://persistent.oaistatic.com/codex-app-prod/ChatGPT.dmg'
  )
fi
sha256sums=('SKIP' "${CODEX_DMG_SHA256:-${_dmg_sha256}}")

build() {
  cd "${srcdir}/codex-desktop-linux"
  MAX_BUILD_THREADS="${MAX_BUILD_THREADS:-$(nproc)}" \
    make build-app DMG="${srcdir}/Codex.dmg"
  MAX_BUILD_THREADS="${MAX_BUILD_THREADS:-$(nproc)}" \
    PACKAGE_NAME="${pkgname}" \
    PACKAGE_DISPLAY_NAME='Codex Desktop' \
    PACKAGE_COMMENT='Run Codex Desktop on Linux' \
    PACKAGE_VERSION="${pkgver}" \
    PACKAGE_WITH_UPDATER="${PACKAGE_WITH_UPDATER:-0}" \
    make pacman
}

package() {
  local package_file

  package_file="$(find "${srcdir}/codex-desktop-linux/dist" -maxdepth 1 \
    -type f -name "${pkgname}-[0-9]*.pkg.tar.*" | sort -V | tail -n 1)"

  if [[ -z "${package_file}" || ! -f "${package_file}" ]]; then
    printf 'Could not find generated package file\n' >&2
    return 1
  fi

  bsdtar -xf "${package_file}" -C "${pkgdir}"
  rm -f "${pkgdir}/.BUILDINFO" "${pkgdir}/.INSTALL" \
    "${pkgdir}/.MTREE" "${pkgdir}/.PKGINFO"

  install -Dm644 "${startdir}/../../DISCLAIMER.md" \
    "${pkgdir}/usr/share/licenses/${pkgname}/DISCLAIMER.md"
}
